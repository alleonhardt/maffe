  'CBsources/AFTModel.cxx',
  'CBsources/ConeModel.cxx',
  'CBsources/NNCModel.cxx',
  'CBsources/NNCData.cxx',
  'CBsources/NNCBoxSupportFunction.cxx',
  'CBsources/NNCBoxSupportModification.cxx',
  'CBsources/NNCModelParameters.cxx',
  'CBsources/BoxData.cxx',
  'CBsources/BoxModel.cxx',
  'CBsources/BoxModelParameters.cxx',
  'CBsources/BoxOracle.cxx',
  'CBsources/SOCData.cxx',
  'CBsources/SOCModel.cxx',
  'CBsources/SOCModelParameters.cxx',
  'CBsources/SOCSupportFunction.cxx',
