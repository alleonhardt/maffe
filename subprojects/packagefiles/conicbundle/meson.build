  'CBsources/QPSolverObject.cxx',
  'CBsources/QPSolver.cxx',
  'CBsources/QPModelBlock.cxx',
  'CBsources/QPSumModelBlock.cxx',
  'CBsources/QPConeModelBlock.cxx',
  'CBsources/InteriorPointBlock.cxx',
  'CBsources/InteriorPointBundleBlock.cxx',
  'CBsources/NNCIPBlock.cxx',
  'CBsources/SOCIPBlock.cxx',
