project(
  'conicbundle',
  'cpp',
  meson_version: '>= 1.3.0',
  default_options: ['cpp_std=c++11', 'warning_level=0'],
)

config = configuration_data()
config.set('CONICBUNDLE_DEBUG', get_option('b_ndebug') == 'false' ? 1 : 0)
configure_file(
  output: 'CBconfig.hxx',
  configuration: config,
)

cpp = meson.get_compiler('cpp')
cb_include_dirs = include_directories('.', 'include', 'CBsources', 'Matrix', 'Tools')

cb_sources = files(
  'Matrix/memarray.cxx',
  'CBsources/CBout.cxx',
  'CBsources/MatrixCBSolver.cxx',
  'CBsources/CBSolver.cxx',
  'CBsources/CB_CSolver.cxx',
