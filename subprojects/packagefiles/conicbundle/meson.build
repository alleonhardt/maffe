  'CBsources/Coeffmat.cxx',
  'CBsources/SparseCoeffmatMatrix.cxx',
  'CBsources/Bigmatrix.cxx',
  'CBsources/ModificationBase.cxx',
  'CBsources/Modification.cxx',
  'CBsources/ModificationTreeData.cxx',
  'CBsources/VariableMetric.cxx',
  'CBsources/VariableMetricSVDSelection.cxx',
  'CBsources/BundleProxObject.cxx',
  'CBsources/BundleIdProx.cxx',
