cb_lib = static_library(
  'cb',
  cb_sources,
  include_directories: cb_include_dirs,
  dependencies: cpp.find_library('m', required: false),
  override_options: ['warning_level=0'],
  install: false,
)

conicbundle_dep = declare_dependency(
  link_with: cb_lib,
  include_directories: cb_include_dirs,
)
